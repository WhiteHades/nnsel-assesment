<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fund_approval_rule_list" model="ir.ui.view">
        <field name="name">fund.approval.rule.list</field>
        <field name="model">fund.approval.rule</field>
        <field name="arch" type="xml">
            <list string="Approval Rules">
                <field name="sequence"/>
                <field name="name"/>
                <field name="request_type"/>
                <field name="min_amount"/>
                <field name="max_amount"/>
                <field name="approver_user_id"/>
                <field name="approver_group_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_fund_approval_rule_form" model="ir.ui.view">
        <field name="name">fund.approval.rule.form</field>
        <field name="model">fund.approval.rule</field>
        <field name="arch" type="xml">
            <form string="Approval Rule">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="active"/>
                            <field name="request_type"/>
                            <field name="sequence"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="min_amount"/>
                            <field name="max_amount"/>
                            <field name="approver_user_id"/>
                            <field name="approver_group_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fund_approval_rule" model="ir.actions.act_window">
        <field name="name">Approval Rules</field>
        <field name="res_model">fund.approval.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_fund_approval_step_list" model="ir.ui.view">
        <field name="name">fund.approval.step.list</field>
        <field name="model">fund.approval.step</field>
        <field name="arch" type="xml">
            <list string="Approval Steps" create="0" edit="0">
                <field name="source_model"/>
                <field name="source_id"/>
                <field name="sequence"/>
                <field name="name"/>
                <field name="approver_user_id"/>
                <field name="approver_group_id"/>
                <field name="state"/>
                <field name="decision_user_id"/>
                <field name="decision_date"/>
            </list>
        </field>
    </record>

    <record id="action_fund_approval_step" model="ir.actions.act_window">
        <field name="name">Approval Steps</field>
        <field name="res_model">fund.approval.step</field>
        <field name="view_mode">list</field>
    </record>

    <record id="view_fund_approval_history_list" model="ir.ui.view">
        <field name="name">fund.approval.history.list</field>
        <field name="model">fund.approval.history</field>
        <field name="arch" type="xml">
            <list string="Approval and Audit History" create="0" edit="0">
                <field name="date"/>
                <field name="source_model"/>
                <field name="source_id"/>
                <field name="action"/>
                <field name="previous_state"/>
                <field name="new_state"/>
                <field name="approval_level"/>
                <field name="user_id"/>
                <field name="amount"/>
                <field name="fund_account_id"/>
                <field name="project_id"/>
                <field name="expense_head_id"/>
                <field name="comment"/>
            </list>
        </field>
    </record>

    <record id="view_fund_approval_history_search" model="ir.ui.view">
        <field name="name">fund.approval.history.search</field>
        <field name="model">fund.approval.history</field>
        <field name="arch" type="xml">
            <search string="Audit History">
                <field name="source_model"/>
                <field name="reference"/>
                <field name="user_id"/>
                <group>
                    <filter string="Action" name="group_action" context="{'group_by': 'action'}"/>
                    <filter string="User" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Model" name="group_model" context="{'group_by': 'source_model'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_fund_approval_history" model="ir.actions.act_window">
        <field name="name">Audit History</field>
        <field name="res_model">fund.approval.history</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_fund_approval_history_search"/>
    </record>
</odoo>
