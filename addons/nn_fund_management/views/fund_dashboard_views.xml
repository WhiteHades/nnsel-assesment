<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fund_dashboard_form" model="ir.ui.view">
        <field name="name">fund.dashboard.form</field>
        <field name="model">fund.dashboard</field>
        <field name="arch" type="xml">
            <form string="Fund Dashboard" create="0" edit="0" delete="0">
                <sheet>
                    <div class="oe_title">
                        <h1>Fund Dashboard</h1>
                    </div>
                    <group class="o_nn_fund_dashboard">
                        <group string="Totals">
                            <field name="currency_id" invisible="1"/>
                            <field name="total_received"/>
                            <field name="unassigned_balance"/>
                            <field name="held_amount"/>
                            <field name="assigned_amount"/>
                            <field name="spent_amount"/>
                            <field name="pending_approval_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Recent Fund Movements">
                            <field name="recent_movement_ids">
                                <list create="0" edit="0">
                                    <field name="date"/>
                                    <field name="movement_type"/>
                                    <field name="bucket"/>
                                    <field name="direction"/>
                                    <field name="amount"/>
                                    <field name="fund_account_id"/>
                                    <field name="project_id"/>
                                    <field name="expense_head_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fund_dashboard" model="ir.actions.act_window">
        <field name="name">Fund Dashboard</field>
        <field name="res_model">fund.dashboard</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="fund_dashboard_main"/>
    </record>
</odoo>
